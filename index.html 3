<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Emotional Cinema</title>

<style>
body {
    margin: 0;
    font-family: 'Helvetica Neue', sans-serif;
    background: linear-gradient(135deg, #f4f7fb, #e6f0f5);
    color: #2b2d42;
    text-align: center;
}

.container {
    padding: 40px 20px;
}

h1 {
    font-weight: 300;
    margin-bottom: 10px;
}

p {
    font-weight: 300;
    opacity: 0.8;
}

textarea {
    width: 80%;
    max-width: 400px;
    height: 90px;
    padding: 15px;
    border-radius: 20px;
    border: 1px solid #ddd;
    resize: none;
    font-size: 15px;
    outline: none;
    margin-top: 20px;
}

button {
    margin-top: 15px;
    padding: 10px 25px;
    border-radius: 25px;
    border: none;
    background-color: #a8dadc;
    color: #1d3557;
    font-size: 15px;
    cursor: pointer;
    transition: 0.3s;
}

button:hover {
    background-color: #8ecae6;
    transform: scale(1.05);
}

.hidden {
    display: none;
}

.fade {
    animation: fadeIn 0.8s ease-in-out;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

.clip-card {
    background: white;
    margin: 15px auto;
    padding: 20px;
    width: 90%;
    max-width: 420px;
    border-radius: 20px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
}

.back-btn {
    background-color: #cdb4db;
}
</style>
</head>

<body>

<div class="container fade" id="home">
    <h1>AI Emotional Cinema</h1>
    <p>Tell me how you feel. I’ll find the moment for you.</p>

    <textarea id="emotionInput" placeholder="Write how you're feeling today..."></textarea>
    <br>
    <button onclick="analyzeEmotion()">Discover</button>
</div>

<div class="container hidden" id="emotionPage">
    <h1 id="emotionTitle"></h1>
    <div id="clips"></div>
    <button class="back-btn" onclick="goBack()">Back</button>
</div>

<script>

const emotionClips = {
    "Happy": ["Joyful Reunion", "Victory Celebration", "Dancing in the Rain"],
    "Angry": ["Breaking Point", "Powerful Confrontation", "Standing Up Strong"],
    "Melancholy": ["Rainy Window Scene", "Late Night Reflection", "Bittersweet Goodbye"],
    "Sad": ["Tears in Silence", "Farewell Scene", "Holding On to Memories"],
    "Lonely": ["City Lights Alone", "Empty Train Ride", "Waiting in Silence"],
    "Warm": ["Family Hug", "Soft Smile Moment", "Golden Sunset Talk"],
    "Relaxed": ["Ocean Waves", "Road Trip Freedom", "Morning Coffee Peace"]
};

function detectEmotion(text) {
    text = text.toLowerCase();

    if (text.match(/happy|joy|excited|great|wonderful|amazing|beautiful/)) return "Happy";
    if (text.match(/angry|mad|furious|frustrated|annoyed|hate/)) return "Angry";
    if (text.match(/melancholy|nostalgic|thoughtful|bittersweet/)) return "Melancholy";
    if (text.match(/sad|cry|heartbroken|miss|loss|pain/)) return "Sad";
    if (text.match(/lonely|alone|empty|isolated/)) return "Lonely";
    if (text.match(/warm|grateful|love|comfort|touched/)) return "Warm";
    if (text.match(/calm|peaceful|relaxed|chill|quiet/)) return "Relaxed";

    return "Melancholy";
}

function analyzeEmotion() {
    const input = document.getElementById("emotionInput").value.trim();

    if (!input) {
        alert("Please write something about how you feel.");
        return;
    }

    const emotion = detectEmotion(input);
    showEmotion(emotion);
}

function showEmotion(emotion) {
    document.getElementById("home").classList.add("hidden");
    document.getElementById("emotionPage").classList.remove("hidden");
    document.getElementById("emotionPage").classList.add("fade");

    document.getElementById("emotionTitle").innerText = "Detected Mood: " + emotion;

    const clipsDiv = document.getElementById("clips");
    clipsDiv.innerHTML = "";

    emotionClips[emotion].forEach(title => {
        clipsDiv.innerHTML += `
            <div class="clip-card fade">
                <h3>${title}</h3>
                <p>Content coming soon...</p>
                <!-- Video placeholder for future upgrade -->
            </div>
        `;
    });
}

function goBack() {
    document.getElementById("emotionPage").classList.add("hidden");
    document.getElementById("home").classList.remove("hidden");
}

</script>

</body>
</html>
